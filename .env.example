# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Get both from Neon dashboard → your project → Connection Details
# DATABASE_URL uses the pooled connection (for Prisma runtime queries)
# DIRECT_URL uses the direct connection (for Prisma migrations/schema push)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# On Vercel: set this to your production URL
# Locally: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL: http://localhost:3000 (or your Vercel URL)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID="your-github-oauth-app-client-id"
GITHUB_SECRET="your-github-oauth-app-client-secret"

# ── Cron security ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Vercel sends this automatically when cron triggers the /api/cron route
CRON_SECRET="your-cron-secret-here"
